#include <iostream>
using namespace std;

int cycle(int n) {
    int cnt = 1;
    while (n != 1) {
        if (n % 2) n = 3 * n + 1;
        else n /= 2;
        cnt++;
    }
    return cnt;
}

int main() {
    int i, j;
    while (cin >> i >> j) {
        int a = i, b = j;
        if (i > j){
            swap(i, j);  
        } 

        int max = 0;
        for (int n = i; n <= j; n++) {
            int c = cycle(n);
            if (c > max){
                max = c;
            }
        }

        cout << a << " " << b << " " << max << endl;
    }
}