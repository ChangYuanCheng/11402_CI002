#include <iostream>
#include <vector>
#include <string>
using namespace std;

int main() {
    int T;
    cin >> T;

    while (T--) {
        int n;
        cin >> n;
        cin.ignore(); // 清掉換行

        vector<int> cmd(n);
        int pos = 0;

        for (int i = 0; i < n; i++) {
            string s;
            getline(cin, s);

            if (s == "LEFT") {
                cmd[i] = -1;
            } 
            else if (s == "RIGHT") {
                cmd[i] = 1;
            } 
            else {
                // 手動抓數字（從第8個字元開始）
                int idx = 0;
                for (int j = 8; j < s.size(); j++) {
                    idx = idx * 10 + (s[j] - '0');
                }
                cmd[i] = cmd[idx - 1];
            }

            pos += cmd[i];
        }

        cout << pos << endl;
    }

    return 0;
}