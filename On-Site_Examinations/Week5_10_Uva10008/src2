#include <iostream>
#include <vector>
#include <algorithm>
#include <cctype>
#include <string>
//數字母 → freq → 負數排序 → 輸出
using namespace std;

int main() {
    int n; cin >> n; cin.ignore();
    int f[26] = {0};
    string s;

    while (n--) {
        getline(cin, s);
        for (char c : s)
            if (isalpha(c))
                f[toupper(c) - 'A']++;
    }

    vector<pair<int,char>> v;
    for (int i = 0; i < 26; i++)
        if (f[i]) v.push_back({-f[i], char('A' + i)});//用「負數」讓排序變降序

    sort(v.begin(), v.end());
    for (auto &p : v)
        cout << p.second << " " << -p.first << "\n";
}