#include <iostream>
using namespace std;

int main() {
    int n;

    while (cin >> n && n != 0) {
        int cnt = 0;
        string bin = "";

        while (n) {
            if (n % 2) {
                bin = "1" + bin;
                cnt++;
            } else {
                bin = "0" + bin;
            }
            n /= 2;
        }

        cout << "The parity of " << bin
             << " is " << cnt << " (mod 2)." << endl;
    }
}